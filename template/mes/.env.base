# 环境
VITE_NODE_ENV=development

# 接口前缀
VITE_API_BASE_PATH=

# 打包路径
VITE_BASE_PATH=/

# 标题
VITE_APP_TITLE=NamesonAdmin

# 是否全量引入element-plus样式
VITE_USE_ALL_ELEMENT_PLUS_STYLE=true

# 是否开启mock
VITE_USE_MOCK=true

# 是否使用在线图标
VITE_USE_ONLINE_ICON=true

# 是否隐藏全局设置按钮
VITE_HIDE_GLOBAL_SETTING=true

# 接口地址
# VITE_BASE_URL = 'http://192.168.88.20:9013/JsonService.asmx'
# 南旋WIP测试地址
VITE_BASE_URL = 'http://10.3.0.167:9001/JsonService.asmx'
